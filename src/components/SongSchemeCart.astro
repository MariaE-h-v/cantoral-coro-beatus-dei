		background: white;
		border: 1px solid #eee7dc;
		box-shadow: 0 12px 26px rgba(15, 23, 42, 0.05);
	}

	.scheme-cart :global(.scheme-song-index) {
		display: inline-flex;
		width: 34px;
		height: 34px;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: #fff7ed;
		color: #9a5f18;
		font-weight: 900;
	}

	.scheme-cart :global(.scheme-song-body) {
		display: grid;
		gap: 2px;
