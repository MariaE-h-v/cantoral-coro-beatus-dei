		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
	}

	.scheme-cart-fab-icon {
		width: 30px;
		height: 30px;
		background: rgba(255, 255, 255, 0.18);
		font-size: 1.2rem;
		line-height: 1;
	}

	.scheme-cart-count {
		min-width: 26px;
		height: 26px;
		padding: 0 7px;
		background: white;
		color: #8f5417;
		font-size: 0.82rem;
	}

	.scheme-cart-backdrop {
		position: fixed;
		inset: 0;
		z-index: 91;
		background: rgba(15, 23, 42, 0.28);
		backdrop-filter: blur(4px);
	}

	.scheme-cart-backdrop[hidden] {
		display: none;
	}

	.scheme-preview-backdrop {
		position: fixed;
		inset: 0;
		z-index: 101;
		background: rgba(15, 23, 42, 0.34);
		backdrop-filter: blur(5px);
	}

	.scheme-preview-backdrop[hidden] {
		display: none;
	}

