<div class="scheme-cart" data-scheme-cart>
	<button
		class="scheme-cart-fab"
		type="button"
		data-scheme-toggle
		aria-controls="songSchemePanel"
		aria-expanded="false"
	>
		<span class="scheme-cart-fab-icon" aria-hidden="true">+</span>
		<span>Separador</span>
		<span class="scheme-cart-count" data-scheme-count>0</span>
	</button>

	<div class="scheme-cart-backdrop" data-scheme-close hidden></div>

	<aside
		id="songSchemePanel"
		class="scheme-cart-panel"
		aria-labelledby="songSchemeTitle"
		aria-hidden="true"
	>
		<div class="scheme-cart-head">
			<div>
				<p>Esquema litúrgico</p>
				<h2 id="songSchemeTitle">Separador de cantos</h2>
			</div>

			<button class="scheme-icon-button" type="button" data-scheme-close aria-label="Cerrar">
				×
			</button>
		</div>

		<div class="scheme-cart-fields">
			<label>
				<span>Nombre del esquema</span>
				<input
					type="text"
					data-scheme-title-input
					placeholder="Misa dominical, boda, retiro..."
				/>
			</label>

			<label>
				<span>Notas</span>
				<textarea
					data-scheme-note-input
					rows="3"
					placeholder="Fecha, parroquia, indicaciones para el coro..."
				></textarea>
			</label>
		</div>

		<div class="scheme-cart-list" data-scheme-list></div>

		<div class="scheme-cart-empty" data-scheme-empty>
			<strong>Aún no hay cantos seleccionados.</strong>
			<span>Agrega cantos desde el listado para armar tu esquema.</span>
		</div>

		<div class="scheme-cart-actions">
			<button class="scheme-primary-action" type="button" data-scheme-preview-open>
				Ver esquema
			</button>
			<button class="scheme-primary-action" type="button" data-scheme-export>
				Exportar PDF
			</button>
			<button class="scheme-secondary-action" type="button" data-scheme-clear>
				Vaciar
			</button>
		</div>
	</aside>

	<div class="scheme-preview-backdrop" data-preview-close hidden></div>

	<section
		id="songSchemePreview"
		class="scheme-preview"
		aria-labelledby="schemePreviewTitle"
		aria-hidden="true"
		hidden
		data-scheme-preview
	>
		<header class="scheme-preview-toolbar">
			<div>
				<p>Vista del esquema</p>
				<h2 id="schemePreviewTitle" data-scheme-preview-title>Esquema de cantos</h2>
			</div>

			<div class="scheme-preview-actions">
				<button class="scheme-primary-action" type="button" data-scheme-preview-export>
					Exportar PDF
				</button>
				<button class="scheme-secondary-action" type="button" data-preview-close>
					Cerrar
				</button>
			</div>
		</header>

		<div class="scheme-preview-body" data-scheme-preview-body></div>
	</section>
</div>

<script type="module">
	const STORAGE_KEY = 'beatus-song-scheme-v1';
	const cartRoot = document.querySelector('[data-scheme-cart]');
	const toggleButton = cartRoot?.querySelector('[data-scheme-toggle]');
	const closeButtons = cartRoot?.querySelectorAll('[data-scheme-close]');
	const panel = cartRoot?.querySelector('.scheme-cart-panel');
	const backdrop = cartRoot?.querySelector('.scheme-cart-backdrop');
	const countBadge = cartRoot?.querySelector('[data-scheme-count]');
	const list = cartRoot?.querySelector('[data-scheme-list]');
	const emptyState = cartRoot?.querySelector('[data-scheme-empty]');
	const previewOpenButton = cartRoot?.querySelector('[data-scheme-preview-open]');
	const exportButton = cartRoot?.querySelector('[data-scheme-export]');
	const previewExportButton = cartRoot?.querySelector('[data-scheme-preview-export]');
	const clearButton = cartRoot?.querySelector('[data-scheme-clear]');
	const titleInput = cartRoot?.querySelector('[data-scheme-title-input]');
	const noteInput = cartRoot?.querySelector('[data-scheme-note-input]');
	const preview = cartRoot?.querySelector('[data-scheme-preview]');
	const previewBackdrop = cartRoot?.querySelector('.scheme-preview-backdrop');
	const previewCloseButtons = cartRoot?.querySelectorAll('[data-preview-close]');
	const previewBody = cartRoot?.querySelector('[data-scheme-preview-body]');
	const previewTitle = cartRoot?.querySelector('[data-scheme-preview-title]');

	const emptyScheme = {
		title: '',
		note: '',
		songs: [],
	};

	let scheme = loadScheme();

	function loadScheme() {
		try {
			const stored = window.localStorage.getItem(STORAGE_KEY);
			if (!stored) return { ...emptyScheme, songs: [] };

			const parsed = JSON.parse(stored);
			return {
				title: parsed.title ?? '',
				note: parsed.note ?? '',
				songs: Array.isArray(parsed.songs) ? parsed.songs : [],
			};
		} catch {
			return { ...emptyScheme, songs: [] };
		}
	}

	function saveScheme() {
		window.localStorage.setItem(STORAGE_KEY, JSON.stringify(scheme));
	}

	function escapeHtml(value) {
		return String(value ?? '')
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#039;');
	}

	function normalizeSong(song) {
		return {
			slug: song.slug,
			title: song.title ?? 'Canto sin título',
			categoria: song.categoria ?? 'Canto',
			tipo: song.tipo ?? 'Canto',
			tiempo: song.tiempo ?? 'Sin tiempo',
			author: song.author ?? 'Autor desconocido',
			description: song.description ?? '',
			href: song.href ?? `/cantos/${song.slug}`,
			lyrics: song.lyrics ?? '',
		};
	}

	function openCart() {
		cartRoot?.classList.add('is-open');
		panel?.setAttribute('aria-hidden', 'false');
		toggleButton?.setAttribute('aria-expanded', 'true');
		if (backdrop) backdrop.hidden = false;
	}

	function closeCart() {
		cartRoot?.classList.remove('is-open');
		panel?.setAttribute('aria-hidden', 'true');
		toggleButton?.setAttribute('aria-expanded', 'false');
		if (backdrop) backdrop.hidden = true;
	}

	function updateButtons() {
		const selectedSlugs = new Set(scheme.songs.map(song => song.slug));

		document.querySelectorAll('[data-song-scheme-add]').forEach(button => {
			const payload = button.getAttribute('data-song-scheme-song');
			if (!payload) return;

			let song;
			try {
				song = JSON.parse(payload);
			} catch {
				return;
			}

			const isSelected = selectedSlugs.has(song.slug);
			button.classList.toggle('is-selected', isSelected);
			button.setAttribute('aria-pressed', String(isSelected));

			const label = button.querySelector('[data-add-label]');
			if (label) {
				label.textContent = isSelected ? 'En esquema' : 'Agregar al esquema';
			}
		});
	}

	function renderList() {
		if (!list || !emptyState) return;

		countBadge.textContent = String(scheme.songs.length);
		emptyState.hidden = scheme.songs.length > 0;
		previewOpenButton.disabled = scheme.songs.length === 0;
		exportButton.disabled = scheme.songs.length === 0;
		previewExportButton.disabled = scheme.songs.length === 0;
		clearButton.disabled = scheme.songs.length === 0;

		if (titleInput && titleInput.value !== scheme.title) {
			titleInput.value = scheme.title;
		}

		if (noteInput && noteInput.value !== scheme.note) {
			noteInput.value = scheme.note;
		}

		list.innerHTML = scheme.songs
			.map((song, index) => {
				const moveUpDisabled = index === 0 ? 'disabled' : '';
				const moveDownDisabled = index === scheme.songs.length - 1 ? 'disabled' : '';

				return `
					<article class="scheme-song-card">
						<div class="scheme-song-index">${index + 1}</div>
						<div class="scheme-song-body">
							<span>${escapeHtml(song.categoria)}</span>
							<strong>${escapeHtml(song.title)}</strong>
							<small>${escapeHtml(song.tiempo)} · ${escapeHtml(song.author)}</small>
						</div>
						<div class="scheme-song-actions">
							<button type="button" data-scheme-move-up="${index}" ${moveUpDisabled} aria-label="Subir ${escapeHtml(song.title)}">↑</button>
							<button type="button" data-scheme-move-down="${index}" ${moveDownDisabled} aria-label="Bajar ${escapeHtml(song.title)}">↓</button>
							<button type="button" data-scheme-remove="${index}" aria-label="Quitar ${escapeHtml(song.title)}">×</button>
						</div>
					</article>
				`;
			})
			.join('');

		updateButtons();

		if (preview && !preview.hidden) {
			renderPreview();
		}
	}

	function addSong(songPayload) {
		const song = normalizeSong(songPayload);
		const exists = scheme.songs.some(item => item.slug === song.slug);

		if (!exists) {
			scheme.songs = [...scheme.songs, song];
			saveScheme();
			renderList();
		}

		openCart();
	}

	function removeSong(index) {
		scheme.songs = scheme.songs.filter((_, songIndex) => songIndex !== index);
		saveScheme();
		renderList();
	}

	function moveSong(index, direction) {
		const nextIndex = index + direction;
		if (nextIndex < 0 || nextIndex >= scheme.songs.length) return;

		const songs = [...scheme.songs];
		const [song] = songs.splice(index, 1);
		songs.splice(nextIndex, 0, song);
		scheme.songs = songs;
		saveScheme();
		renderList();
	}

	function formatLyrics(lyrics) {
		const cleanLyrics = String(lyrics ?? '').replace(/^\s*\n/, '').replace(/\s+$/, '');
		if (!cleanLyrics) return 'No hay letra registrada para este canto.';

		return escapeHtml(cleanLyrics);
	}

	function buildPrintDocument() {
		const title = scheme.title.trim() || 'Esquema de cantos';
		const note = scheme.note.trim();
		const date = new Intl.DateTimeFormat('es-MX', { dateStyle: 'long' }).format(new Date());

		return `
			<div class="scheme-print-page">
				<header class="scheme-print-header">
					<p>Cantoral Coro Beatus Dei</p>
					<h1>${escapeHtml(title)}</h1>
					<span>${escapeHtml(date)}</span>
					${note ? `<div class="scheme-print-note">${escapeHtml(note)}</div>` : ''}
				</header>

				<section class="scheme-print-index">
					<h2>Orden del esquema</h2>
					<ol>
						${scheme.songs
							.map(song => `<li>${escapeHtml(song.title)} <span>${escapeHtml(song.categoria)}</span></li>`)
							.join('')}
					</ol>
				</section>

				${scheme.songs
					.map((song, index) => `
						<section class="scheme-print-song">
							<p class="scheme-print-kicker">${index + 1}. ${escapeHtml(song.categoria)}</p>
							<h2>${escapeHtml(song.title)}</h2>
							<div class="scheme-print-meta">
								<span>${escapeHtml(song.tiempo)}</span>
								<span>${escapeHtml(song.tipo)}</span>
								<span>${escapeHtml(song.author)}</span>
							</div>
							${song.description ? `<p class="scheme-print-description">${escapeHtml(song.description)}</p>` : ''}
							<pre class="scheme-print-lyrics"><code>${formatLyrics(song.lyrics)}</code></pre>
						</section>
					`)
					.join('')}
			</div>
		`;
	}

	function buildPreviewDocument() {
		const title = scheme.title.trim() || 'Esquema de cantos';
		const note = scheme.note.trim();
		const date = new Intl.DateTimeFormat('es-MX', { dateStyle: 'long' }).format(new Date());

		return `
			<article class="scheme-preview-document">
				<header class="scheme-preview-hero">
					<p>Cantoral Coro Beatus Dei</p>
					<h1>${escapeHtml(title)}</h1>
					<span>${escapeHtml(date)}</span>
					${note ? `<div class="scheme-preview-note">${escapeHtml(note)}</div>` : ''}
				</header>

				<section class="scheme-preview-index">
					<h2>Orden del esquema</h2>
					<ol>
						${scheme.songs
							.map((song, index) => `
								<li>
									<a href="#scheme-preview-song-${index + 1}">
										<strong>${index + 1}. ${escapeHtml(song.title)}</strong>
										<span>${escapeHtml(song.categoria)}</span>
									</a>
								</li>
							`)
							.join('')}
					</ol>
				</section>

				${scheme.songs
					.map((song, index) => `
						<section id="scheme-preview-song-${index + 1}" class="scheme-preview-song">
							<div class="scheme-preview-song-head">
								<div>
									<p>${index + 1}. ${escapeHtml(song.categoria)}</p>
									<h2>${escapeHtml(song.title)}</h2>
								</div>
								<a href="${escapeHtml(song.href)}">Detalle</a>
							</div>
							<div class="scheme-preview-meta">
								<span>${escapeHtml(song.tiempo)}</span>
								<span>${escapeHtml(song.tipo)}</span>
								<span>${escapeHtml(song.author)}</span>
							</div>
							${song.description ? `<p class="scheme-preview-description">${escapeHtml(song.description)}</p>` : ''}
							<pre class="scheme-preview-lyrics"><code>${formatLyrics(song.lyrics)}</code></pre>
						</section>
					`)
					.join('')}
			</article>
		`;
	}

	function renderPreview() {
		const title = scheme.title.trim() || 'Esquema de cantos';

		if (previewTitle) {
			previewTitle.textContent = title;
		}

		if (previewBody) {
			previewBody.innerHTML = buildPreviewDocument();
		}
	}

	function openPreview() {
		if (!scheme.songs.length) {
			openCart();
			return;
		}

		renderPreview();
		closeCart();
		if (preview) {
			preview.hidden = false;
			preview.setAttribute('aria-hidden', 'false');
		}
		if (previewBackdrop) previewBackdrop.hidden = false;
		document.body.setAttribute('data-scheme-previewing', 'true');
	}

	function closePreview() {
		if (preview) {
			preview.hidden = true;
			preview.setAttribute('aria-hidden', 'true');
		}
		if (previewBackdrop) previewBackdrop.hidden = true;
		document.body.removeAttribute('data-scheme-previewing');
	}

	function exportScheme() {
		if (!scheme.songs.length) {
			openCart();
			return;
		}

		const printDocument = document.createElement('div');
		printDocument.className = 'scheme-print-document';
		printDocument.innerHTML = buildPrintDocument();
		document.body.appendChild(printDocument);
		document.body.setAttribute('data-printing-scheme', 'true');

		const cleanup = () => {
			document.body.removeAttribute('data-printing-scheme');
			printDocument.remove();
			window.removeEventListener('afterprint', cleanup);
		};

		window.addEventListener('afterprint', cleanup);
		window.requestAnimationFrame(() => {
			window.print();
			window.setTimeout(cleanup, 30000);
		});
	}

	document.addEventListener('click', event => {
		const target = event.target instanceof Element ? event.target : null;
		const addButton = target?.closest('[data-song-scheme-add]');
		if (!addButton) return;

		event.preventDefault();
		event.stopPropagation();

		try {
			addSong(JSON.parse(addButton.getAttribute('data-song-scheme-song')));
		} catch {
			openCart();
		}
	});
	document.addEventListener('song-scheme-cards-rendered', updateButtons);

	list?.addEventListener('click', event => {
		const target = event.target instanceof Element ? event.target : null;
		const removeButton = target?.closest('[data-scheme-remove]');
		const moveUpButton = target?.closest('[data-scheme-move-up]');
		const moveDownButton = target?.closest('[data-scheme-move-down]');

		if (removeButton) {
			removeSong(Number(removeButton.dataset.schemeRemove));
		}

		if (moveUpButton) {
			moveSong(Number(moveUpButton.dataset.schemeMoveUp), -1);
		}

		if (moveDownButton) {
			moveSong(Number(moveDownButton.dataset.schemeMoveDown), 1);
		}
	});

	toggleButton?.addEventListener('click', () => {
		if (cartRoot?.classList.contains('is-open')) {
			closeCart();
		} else {
			openCart();
		}
	});

	closeButtons?.forEach(button => button.addEventListener('click', closeCart));
	previewCloseButtons?.forEach(button => button.addEventListener('click', closePreview));
	previewOpenButton?.addEventListener('click', openPreview);
	exportButton?.addEventListener('click', exportScheme);
	previewExportButton?.addEventListener('click', exportScheme);

	clearButton?.addEventListener('click', () => {
		if (!scheme.songs.length) return;
		scheme.songs = [];
		saveScheme();
		renderList();
		closePreview();
	});

	titleInput?.addEventListener('input', () => {
		scheme.title = titleInput.value;
		saveScheme();
		if (preview && !preview.hidden) renderPreview();
	});

	noteInput?.addEventListener('input', () => {
		scheme.note = noteInput.value;
		saveScheme();
		if (preview && !preview.hidden) renderPreview();
	});

	window.addEventListener('keydown', event => {
		if (event.key === 'Escape') {
			if (preview && !preview.hidden) {
				closePreview();
			} else {
				closeCart();
			}
		}
	});

	renderList();
</script>

<style>
	.scheme-cart {
		position: relative;
		z-index: 90;
		font-family: Inter, system-ui, sans-serif;
	}

	.scheme-cart-fab {
