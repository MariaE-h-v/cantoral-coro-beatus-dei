---
import path from 'node:path';
import { getLiturgicalBackground } from '../utils/liturgicalSeason';

interface Props {
	placeholder?: string;
}

const {
	placeholder = 'Buscar cantos por título, autor, tema o celebración...',
} = Astro.props;

const rawSongs = import.meta.glob('../content/cantos/*.md', { eager: true });

const songs = Object.entries(rawSongs).map(([file, module]) => {
	const data = (module as any).frontmatter ?? {};
	const slug = path.basename(file, '.md');

	return {
		title: data.title ?? slug,
		categoria: data.categoria ?? '',
		tipo: data.tipo ?? '',
		tiempo: data.tiempo ?? '',
		author: data.author ?? '',
		liturgico: Boolean(data.liturgico),
		tags: Array.isArray(data.tags) ? data.tags : [],
		description: data.description ?? '',
		slug,
		href: `/cantos/${slug}`,
		seasonBackground: getLiturgicalBackground(data.tiempo, data.tags),
	};
});
---

<div class="song-search" data-songs={JSON.stringify(songs)}>
	<form class="song-search-form" action="/cantos" method="get" autocomplete="off">
		<label for="songSearchInput" class="visually-hidden">Buscar cantos</label>

		<input
			id="songSearchInput"
			class="song-search-input"
			name="q"
			type="search"
			placeholder={placeholder}
			aria-autocomplete="list"
			aria-controls="songSearchSuggestions"
			aria-expanded="false"
		/>

		<button class="song-search-button" type="submit">
			Buscar
		</button>
	</form>

	<div
		id="songSearchSuggestions"
		class="song-search-suggestions"
		role="listbox"
		hidden
	></div>
</div>

<style>
	.song-search {
		position: relative;
		width: min(100%, 720px);
		z-index: 20;
	}

	.song-search-form {
		position: relative;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 12px;
		width: 100%;
		padding: 8px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 18px 60px rgba(15, 23, 42, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.7);
		box-sizing: border-box;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.song-search-form:focus-within {
		border-color: rgba(200, 144, 47, 0.45);
		box-shadow:
			0 18px 60px rgba(15, 23, 42, 0.14),
			0 0 0 4px rgba(200, 144, 47, 0.16);
	}

	.song-search-input {
		width: 100%;
		min-width: 0;
		padding: 16px 20px;
		border: none;
		background: transparent;
		font-size: 1rem;
		color: #111827;
		outline: none;
		box-sizing: border-box;
	}

	.song-search-input::placeholder {
		color: #94a3b8;
	}

	.song-search-button {
		border: none;
		border-radius: 999px;
		padding: 0 34px;
		background: linear-gradient(135deg, #d49b37 0%, #b27722 100%);
		color: white;
		font-weight: 800;
		font-size: 1rem;
		cursor: pointer;
		box-shadow: 0 14px 30px rgba(178, 119, 34, 0.25);
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.song-search-button:hover {
		box-shadow: 0 18px 34px rgba(178, 119, 34, 0.32);
		transform: translateY(-1px);
	}

	.song-search-button:focus-visible {
		outline: 3px solid rgba(200, 144, 47, 0.35);
		outline-offset: 3px;
	}

	.song-search-suggestions {
		position: absolute;
		top: calc(100% + 10px);
		left: 0;
		right: 0;
		z-index: 50;
		max-height: min(68vh, 560px);
		overflow-y: auto;
		padding: 10px;
		border-radius: 26px;
		background:
			linear-gradient(180deg, rgba(255, 248, 239, 0.96) 0%, rgba(255, 255, 255, 0.98) 44%),
			rgba(255, 255, 255, 0.98);
		border: 1px solid rgba(238, 231, 220, 0.95);
		box-shadow:
			0 28px 90px rgba(15, 23, 42, 0.18),
			0 1px 0 rgba(255, 255, 255, 0.9) inset;
		backdrop-filter: blur(14px);
		box-sizing: border-box;
	}

	.song-search-suggestions[hidden] {
		display: none;
	}

	.song-search :global(.suggestion-panel-head) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 8px 10px 12px;
		color: #7c5c32;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.song-search :global(.suggestion-count) {
		letter-spacing: 0;
		text-transform: none;
		color: #64748b;
		font-size: 0.78rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.song-search :global(.suggestion-item) {
		position: relative;
		display: grid;
		grid-template-columns: 36px minmax(0, 1fr) auto;
		gap: 24px;
		align-items: center;
		width: 100%;
		margin: 0;
		padding: 14px;
		border-radius: 18px;
		color: #111827;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid transparent;
		box-sizing: border-box;
		transition:
			border-color 0.18s ease,
			background 0.18s ease,
			box-shadow 0.18s ease,
			transform 0.18s ease;
	}

	.song-search :global(.suggestion-item + .suggestion-item) {
		margin-top: 6px;
	}

	.song-search :global(.suggestion-item:hover),
	.song-search :global(.suggestion-item.is-active) {
		background: linear-gradient(135deg, #fff7ed 0%, #fffdf8 100%);
		border-color: rgba(200, 144, 47, 0.24);
		box-shadow: 0 14px 34px rgba(120, 74, 20, 0.12);
		transform: translateY(-1px);
	}

	.song-search :global(.suggestion-item.has-season-background) {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(255, 250, 244, 0.88)),
			var(--song-card-bg) center / cover no-repeat,
			rgba(255, 255, 255, 0.72);
		border-color: rgba(178, 119, 34, 0.16);
	}

	.song-search :global(.suggestion-item.has-season-background:hover),
	.song-search :global(.suggestion-item.has-season-background.is-active) {
		background:
			linear-gradient(135deg, rgba(255, 247, 237, 0.94), rgba(255, 253, 248, 0.9)),
			var(--song-card-bg) center / cover no-repeat,
			white;
	}

	.song-search :global(.suggestion-icon) {
		display: inline-flex;
		width: 36px;
		height: 36px;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		background:
			linear-gradient(135deg, rgba(255, 247, 237, 0.98), rgba(248, 239, 226, 0.98));
		color: #9a5f18;
		font-size: 0.95rem;
		font-weight: 800;
		border: 1px solid #f1e4d1;
		box-shadow: 0 10px 22px rgba(120, 74, 20, 0.08);
		box-sizing: border-box;
	}

	.song-search :global(.suggestion-icon img) {
		width: 36px;
		height: 36px;
		object-fit: contain;
	}

	.song-search :global(.suggestion-content) {
		min-width: 0;
	}

	.song-search :global(.suggestion-kicker) {
		display: block;
		margin: 0 0 3px;
		color: #b27722;
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.song-search :global(.suggestion-title) {
		display: block;
		margin: 4px;
		font-size: 1.02rem;
		font-weight: 800;
		color: #111827;
		line-height: 1.28;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.song-search :global(.suggestion-description) {
		display: -webkit-box;
		margin-top: 4px;
		color: #64748b;
		font-size: 0.86rem;
		line-height: 1.45;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.song-search :global(.suggestion-meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 9px;
		font-size: 0.82rem;
		color: #64748b;
	}

	.song-search :global(.suggestion-meta span) {
		display: inline-flex;
		align-items: center;
		max-width: 100%;
		padding: 0.28em 0.68em;
		border-radius: 999px;
		background: #f8fafc;
		border: 1px solid #e5e7eb;
		color: #475569;
		font-weight: 700;
		white-space: nowrap;
	}

	.song-search :global(.suggestion-badge) {
		display: inline-flex;
		align-items: start;
		gap: 9px;
		margin-top: 2px;
		padding: 0.36em 0.72em;
		border-radius: 999px;
		background: rgba(255, 247, 237, 0.86);
		border: 1px solid rgba(200, 144, 47, 0.22);
		color: #8a520f;
		font-size: 0.76rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.song-search :global(.suggestion-badge::after) {
		content: '›';
		color: #b27722;
		font-size: 1.05rem;
		line-height: 1;
	}

	.song-search :global(.suggestion-empty) {
		padding: 22px 18px;
		border-radius: 18px;
		background: rgba(248, 250, 252, 0.82);
		border: 1px dashed #d8c8af;
		color: #64748b;
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 720px) {
		.song-search-form {
			grid-template-columns: 1fr;
			border-radius: 24px;
		}

		.song-search-button {
			min-height: 52px;
		}

		.song-search-suggestions {
			border-radius: 22px;
			padding: 8px;
		}

		.song-search :global(.suggestion-item) {
			grid-template-columns: 32px minmax(0, 1fr);
			gap: 12px;
			padding: 12px;
		}

		.song-search :global(.suggestion-badge) {
			display: none;
		}

		.song-search :global(.suggestion-icon) {
			width: 32px;
			height: 32px;
			border-radius: 11px;
		}

		.song-search :global(.suggestion-title) {
			white-space: normal;
		}

		.song-search :global(.suggestion-description) {
			-webkit-line-clamp: 1;
		}

		.song-search :global(.suggestion-panel-head) {
			align-items: flex-start;
			flex-direction: column;
			gap: 4px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.song-search-form,
		.song-search-button,
		.song-search :global(.suggestion-item) {
			transition: none;
		}

		.song-search-button:hover,
		.song-search :global(.suggestion-item:hover),
		.song-search :global(.suggestion-item.is-active) {
			transform: none;
		}
	}
</style>

<script>
	const searchRoot = document.querySelector('.song-search');
	const input = searchRoot?.querySelector('.song-search-input');
	const form = searchRoot?.querySelector('.song-search-form');
	const suggestionsBox = searchRoot?.querySelector('.song-search-suggestions');

	const songs = JSON.parse(searchRoot?.getAttribute('data-songs') ?? '[]');

	let activeIndex = -1;
	let currentResults = [];

	function normalizeText(value) {
		return String(value ?? '')
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '')
			.toLowerCase()
			.trim();
	}

	function escapeHtml(value) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function getSearchText(song) {
		return normalizeText([
			song.title,
			song.categoria,
			song.tipo,
			song.tiempo,
			song.author,
			song.description,
			...(song.tags ?? []),
		].join(' '));
	}

	function getCategoryIcon(song) {
		const category = normalizeText(song.categoria);

		if (category.includes('entrada')) return '/icons/entrada.svg';
		if (category.includes('ofertorio')) return '/icons/ofertorio.svg';
		if (category.includes('comunion')) return '/icons/comunion.svg';
		if (category.includes('salida')) return '/icons/salida.svg';
		if (category.includes('comun')) return '/icons/comun.svg';

		return '';
	}

	function getFallbackIcon(song) {
		const category = normalizeText(song.categoria);

		if (category.includes('gloria')) return '♪';
		if (category.includes('aleluya')) return '♫';
		if (category.includes('santo')) return '✝';

		return '♬';
	}

	function getIconMarkup(song) {
		const icon = getCategoryIcon(song);

		if (icon) {
			return `<img src="${escapeHtml(icon)}" alt="" loading="lazy"  />`;
		}

		return escapeHtml(getFallbackIcon(song));
	}

	function getDescription(song) {
		return song.description || 'Canto disponible para consulta dentro del cantoral.';
	}

	function getResults(query) {
		const normalizedQuery = normalizeText(query);

		if (!normalizedQuery) {
			return [];
		}

		return songs
			.map(song => {
				const title = normalizeText(song.title);
				const author = normalizeText(song.author);
				const category = normalizeText(song.categoria);
				const type = normalizeText(song.tipo);
				const season = normalizeText(song.tiempo);
				const tags = normalizeText((song.tags ?? []).join(' '));
				const description = normalizeText(song.description);
				const fullText = getSearchText(song);

				let score = 0;

				if (title === normalizedQuery) score += 120;
				if (title.startsWith(normalizedQuery)) score += 90;
				if (title.includes(normalizedQuery)) score += 70;

				if (author.startsWith(normalizedQuery)) score += 45;
				if (author.includes(normalizedQuery)) score += 35;

				if (category.includes(normalizedQuery)) score += 32;
				if (type.includes(normalizedQuery)) score += 30;
				if (season.includes(normalizedQuery)) score += 28;
				if (tags.includes(normalizedQuery)) score += 25;
				if (description.includes(normalizedQuery)) score += 18;
				if (fullText.includes(normalizedQuery)) score += 12;

				return {
					...song,
					score,
				};
			})
			.filter(song => song.score > 0)
			.sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
			.slice(0, 7);
	}

	function renderSuggestions(results, query) {
		if (!suggestionsBox || !input) return;

		suggestionsBox.innerHTML = '';
		activeIndex = -1;

		if (!query.trim()) {
			suggestionsBox.hidden = true;
			input.setAttribute('aria-expanded', 'false');
			return;
		}

		if (!results.length) {
			suggestionsBox.hidden = false;
			input.setAttribute('aria-expanded', 'true');

			const empty = document.createElement('div');
			empty.className = 'suggestion-empty';
			empty.textContent = 'No se encontraron cantos con esa búsqueda.';
			suggestionsBox.appendChild(empty);
			return;
		}

		const panelHead = document.createElement('div');
		panelHead.className = 'suggestion-panel-head';
		panelHead.setAttribute('role', 'presentation');
		panelHead.innerHTML = `
			<span>Coincidencias</span>
			<span class="suggestion-count">${results.length} ${results.length === 1 ? 'canto' : 'cantos'}</span>
		`;
		suggestionsBox.appendChild(panelHead);

		results.forEach((song, index) => {
			const item = document.createElement('a');

			item.className = 'suggestion-item';
			if (song.seasonBackground) {
				item.classList.add('has-season-background');
				item.style.setProperty('--song-card-bg', `url("${song.seasonBackground}")`);
			}
			item.href = song.href;
			item.setAttribute('role', 'option');
			item.setAttribute('data-index', String(index));

			const metaParts = [
				song.tiempo,
				song.author,
			].filter(Boolean);
			const categoryLabel = song.categoria || song.tipo || 'Canto';

			item.innerHTML = `
				<span class="suggestion-icon" aria-hidden="true">${getIconMarkup(song)}</span>

				<span class="suggestion-content">
					<span class="suggestion-kicker">${escapeHtml(categoryLabel)}</span>
					<strong class="suggestion-title">${escapeHtml(song.title)}</strong>
					<span class="suggestion-description">${escapeHtml(getDescription(song))}</span>
					<span class="suggestion-meta">
						${metaParts.map(part => `<span>${escapeHtml(part)}</span>`).join('\n')}
					</span>
				</span>

				<span class="suggestion-badge">
					${song.liturgico ? 'Litúrgico' : 'Revisar'}
				</span>
			`;

			item.addEventListener('mouseenter', () => {
				setActiveIndex(index);
			});

			suggestionsBox.appendChild(item);
		});

		suggestionsBox.hidden = false;
		input.setAttribute('aria-expanded', 'true');
	}

	function setActiveIndex(index) {
		if (!suggestionsBox) return;

		const items = suggestionsBox.querySelectorAll('.suggestion-item');

		items.forEach(item => item.classList.remove('is-active'));

		activeIndex = index;

		if (items[activeIndex]) {
			items[activeIndex].classList.add('is-active');
		}
	}

	function goToSong(song) {
		if (!song?.href) return;
		window.location.href = song.href;
	}

	input?.addEventListener('input', event => {
		const query = event.target.value;
		currentResults = getResults(query);
		renderSuggestions(currentResults, query);
	});

	input?.addEventListener('focus', event => {
		const query = event.target.value;
		currentResults = getResults(query);
		renderSuggestions(currentResults, query);
	});

	input?.addEventListener('keydown', event => {
		if (!currentResults.length) return;

		if (event.key === 'ArrowDown') {
			event.preventDefault();
			const nextIndex = activeIndex < currentResults.length - 1 ? activeIndex + 1 : 0;
			setActiveIndex(nextIndex);
		}

		if (event.key === 'ArrowUp') {
			event.preventDefault();
			const previousIndex = activeIndex > 0 ? activeIndex - 1 : currentResults.length - 1;
			setActiveIndex(previousIndex);
		}

		if (event.key === 'Enter') {
			if (activeIndex >= 0 && currentResults[activeIndex]) {
				event.preventDefault();
				goToSong(currentResults[activeIndex]);
			}
		}

		if (event.key === 'Escape') {
			suggestionsBox.hidden = true;
			input.setAttribute('aria-expanded', 'false');
		}
	});

	form?.addEventListener('submit', event => {
		const query = input?.value ?? '';
		const results = getResults(query);

		if (results.length) {
			event.preventDefault();
			goToSong(results[0]);
		}
	});

	document.addEventListener('click', event => {
		if (!searchRoot?.contains(event.target)) {
			if (suggestionsBox) suggestionsBox.hidden = true;
			input?.setAttribute('aria-expanded', 'false');
		}
	});
</script>
