---
import Analytics from '@vercel/analytics/astro';
import { socialLinks } from '../data/socialLinks';
import SongSchemeCart from '../components/SongSchemeCart.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Cantoral Coro Beatus Dei</title>
	</head>

	<body>
		<div class="page-shell">
			<header class="site-header">
				<div class="brand-group">
					<a href="/" aria-label="Ir al inicio">
						<img
							class="brand-logo"
							src="/logo.svg"
							alt="Cantoral Coro Beatus Dei"
						/>
					</a>
				</div>

				<nav class="site-nav" aria-label="Navegación principal">
					<a href="/">Inicio</a>
					<a href="/cantos">Cantos</a>
					<a href="/tiempos-liturgicos">Tiempos Litúrgicos</a>
					<a href="/tipos-de-misas">Tipos de Misas</a>
					<a href="/recursos">Recursos</a>
					<a href="/sobre-nosotros">Sobre nosotros</a>
					<a href="#contacto">Contacto</a>
				</nav>
			</header>

			<main>
				<slot />
			</main>

			<footer id="contacto" class="site-footer">
				<div class="footer-inner">
					<div class="footer-grid">
						<div class="footer-column footer-brand">
							<img
								class="footer-brand-logo"
								src="/logo.svg"
								alt="Cantoral Coro Beatus Dei"
							/>

							<p class="footer-copy">
								Un espacio para descubrir, aprender y compartir cantos que ayudan
								a celebrar nuestra fe.
							</p>
						</div>

						<div class="footer-column footer-links">
							<p class="footer-title">Navegación</p>
							<a href="/">Inicio</a>
							<a href="/cantos">Cantos</a>
							<a href="/tiempos-liturgicos">Tiempos Litúrgicos</a>
							<a href="/tipos-de-misas">Tipos de Misas</a>
							<a href="/recursos">Recursos</a>
							<a href="/donativos">Donativos</a>
						</div>

						<div class="footer-column footer-links">
							<p class="footer-title">Enlaces útiles</p>
							<a href="/sobre-nosotros">Sobre nosotros</a>
							<a href="#contacto">Contacto</a>
						</div>

						<div class="footer-column footer-meta">
							<p class="footer-title">Contacto</p>
							<a href="mailto:corobeatusdei@gmail.com">
								corobeatusdei@gmail.com
							</a>
							<p>Saltillo, Coahuila, México</p>
							<p>+52 8771377485</p>

							<div class="footer-social" aria-label="Redes sociales">
								{socialLinks.map(link => (
									<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.name}>
										<span>{link.icon}</span>
									</a>
								))}
							</div>
						</div>
					</div>

					<div class="footer-bottom">
						<p>
							© {new Date().getFullYear()} Cantoral Coro Beatus Dei.
							Todos los derechos reservados.
						</p>
					</div>
				</div>
			</footer>

			<SongSchemeCart />
			<Analytics />
		</div>

		<script>
			let lastScrollY = 0;
			let ticking = false;
			const header = document.querySelector('.site-header');

			function updateHeaderVisibility() {
				const currentScrollY = window.scrollY;
				const isScrollingDown = currentScrollY > lastScrollY;
				const isAtTop = currentScrollY < 50;

				if (isAtTop) {
					header?.classList.remove('hide');
				} else if (isScrollingDown) {
					header?.classList.add('hide');
				} else {
					header?.classList.remove('hide');
				}

				lastScrollY = currentScrollY;
				ticking = false;
			}

			window.addEventListener('scroll', () => {
				if (!ticking) {
					window.requestAnimationFrame(updateHeaderVisibility);
					ticking = true;
				}
			});
		</script>
	</body>

	<style>
		html,
		body {
			margin: 0;
			width: 100%;
			min-height: 100%;
			background: #fbf3e8;
			color: #0f172a;
			font-family:
				Inter,
				ui-sans-serif,
				system-ui,
				-apple-system,
				BlinkMacSystemFont,
				'Segoe UI',
				sans-serif;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			-webkit-font-smoothing: antialiased;
			text-rendering: optimizeLegibility;
			overflow-x: hidden;
		}

		* {
			box-sizing: border-box;
		}

		.page-shell {
			display: flex;
			flex-direction: column;
			min-height: 100vh;
			padding-top: 76px;
		}

		main {
			flex: 1;
		}

		.site-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			gap: 24px;
			padding: 18px clamp(20px, 3vw, 34px);
			background: rgba(255, 255, 255, 0.96);
			backdrop-filter: blur(18px);
			border-bottom: 1px solid #f2e5cd;
			box-shadow: 0 18px 60px rgba(15, 23, 42, 0.06);
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 40;
			transition:
				transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
				background 0.3s ease;
		}

		.site-header.hide {
			transform: translateY(-100%);
		}

		.brand-group {
			display: flex;
			align-items: center;
			gap: 18px;
			flex: 0 0 auto;
		}

		.brand-group a {
			display: inline-flex;
			align-items: center;
			text-decoration: none;
		}

		.brand-logo {
			width: 250px;
			height: auto;
			max-width: 100%;
			display: block;
		}

		.site-nav {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: flex-end;
			gap: 8px;
		}

		.site-nav a {
			color: #475569;
			text-decoration: none;
			font-size: 0.94rem;
			font-weight: 700;
			padding: 11px 13px;
			border-radius: 999px;
			transition:
				background 0.2s ease,
				color 0.2s ease,
				transform 0.2s ease;
		}

		.site-nav a:hover {
			color: #111827;
			background: rgba(242, 197, 173, 0.22);
			transform: translateY(-1px);
		}

		.site-footer {
			margin-top: 64px;
			padding: 0 20px 28px;
			background:
				radial-gradient(
					circle at top left,
					rgba(200, 144, 47, 0.12),
					transparent 34%
				),
				linear-gradient(180deg, #f8f1e8 0%, #f5ede3 100%);
			border-top: 1px solid rgba(178, 119, 34, 0.14);
			color: #1f2937;
		}

		.footer-inner {
			width: min(1160px, 100%);
			margin: 0 auto;
			padding-top: 46px;
		}

		.footer-grid {
			display: grid;
			grid-template-columns: 1.3fr 1fr 1fr 1fr;
			gap: 36px;
			align-items: start;
		}

		.footer-column {
			display: flex;
			flex-direction: column;
		}

		.footer-brand {
			max-width: 350px;
		}

		.footer-brand-logo {
			width: 230px;
			max-width: 100%;
			height: auto;
			display: block;
			margin-bottom: 16px;
		}

		.footer-title {
			margin: 0 0 14px;
			font-size: 0.92rem;
			font-weight: 800;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: #8b5e1a;
		}

		.footer-copy,
		.footer-meta p {
			margin: 0;
			font-size: 0.95rem;
			line-height: 1.8;
			color: #64748b;
		}

		.footer-links a,
		.footer-meta > a {
			display: inline-block;
			width: fit-content;
			margin-top: 10px;
			font-size: 0.95rem;
			line-height: 1.6;
			color: #475569;
			text-decoration: none;
			transition:
				color 0.2s ease,
				transform 0.2s ease;
		}

		.footer-links a:hover,
		.footer-meta > a:hover {
			color: #b27722;
			transform: translateX(3px);
		}

		.footer-meta {
			align-items: flex-start;
		}

		.footer-meta p + p,
		.footer-meta a + p {
			margin-top: 10px;
		}

		.footer-social {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
			margin-top: 18px;
		}

		.footer-social a {
			display: inline-flex;
			flex: 0 0 40px;
			width: 40px;
			height: 40px;
			aspect-ratio: 1;
			align-items: center;
			justify-content: center;
			padding: 0;
			margin: 0;
			border-radius: 50%;
			background: white;
			color: #0f766e;
			font-size: 1rem;
			font-weight: 900;
			box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
			transition:
				background 0.2s ease,
				color 0.2s ease,
				transform 0.2s ease;
		}

		.footer-social a:hover {
			background: #0f766e;
			color: white;
			transform: translateY(-2px);
		}

		.footer-social span {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 1em;
			height: 1em;
			line-height: 1;
		}

		.footer-bottom {
			margin-top: 38px;
			padding-top: 20px;
			border-top: 1px solid rgba(178, 119, 34, 0.14);
			text-align: center;
		}

		.footer-bottom p {
			margin: 0;
			font-size: 0.9rem;
			color: #64748b;
			line-height: 1.7;
		}

		@media (max-width: 1180px) {
			.site-header {
				align-items: flex-start;
			}

			.brand-logo {
				width: 220px;
			}

			.site-nav {
				gap: 6px;
			}

			.site-nav a {
				font-size: 0.9rem;
				padding: 10px 11px;
			}
		}

		@media (max-width: 960px) {
			.page-shell {
				padding-top: 128px;
			}

			.site-header {
				flex-direction: column;
				align-items: center;
				gap: 14px;
			}

			.brand-logo {
				width: 240px;
			}

			.site-nav {
				justify-content: center;
			}

			.footer-grid {
				grid-template-columns: 1fr 1fr;
				gap: 32px;
			}

			.footer-brand {
				max-width: 100%;
			}
		}

		@media (max-width: 720px) {
			.page-shell {
				padding-top: 132px;
			}

			.site-header {
				padding: 16px 18px;
			}

			.brand-logo {
				width: 220px;
			}

			.site-nav {
				width: 100%;
				justify-content: flex-start;
				flex-wrap: nowrap;
				overflow-x: auto;
				padding-bottom: 4px;
				scrollbar-width: none;
			}

			.site-nav::-webkit-scrollbar {
				display: none;
			}

			.site-nav a {
				flex: 0 0 auto;
				font-size: 0.88rem;
				padding: 10px 12px;
			}

			.site-footer {
				margin-top: 48px;
				padding: 0 18px 24px;
			}

			.footer-inner {
				padding-top: 38px;
			}

			.footer-grid {
				grid-template-columns: 1fr;
				gap: 28px;
				text-align: center;
			}

			.footer-column,
			.footer-meta {
				align-items: center;
			}

			.footer-brand-logo {
				margin-left: auto;
				margin-right: auto;
			}

			.footer-links a,
			.footer-meta > a {
				width: auto;
			}

			.footer-links a:hover,
			.footer-meta > a:hover {
				transform: none;
			}

			.footer-social {
				justify-content: center;
			}

			.footer-social a {
				flex-basis: 40px;
				width: 40px;
				min-width: 40px;
				max-width: 40px;
				height: 40px;
			}

			.footer-social a:hover {
				transform: translateY(-2px);
			}

			.footer-bottom {
				margin-top: 28px;
			}
		}

		@media (max-width: 480px) {
			.page-shell {
				padding-top: 126px;
			}

			.brand-logo {
				width: 200px;
			}

			.site-nav a {
				font-size: 0.84rem;
			}
		}
	</style>
</html>
