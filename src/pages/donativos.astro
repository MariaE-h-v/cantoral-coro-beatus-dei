---
import Layout from '../layouts/Layout.astro';
import '../styles/donations.css';
import bannerImage from '../assets/bannerHome.png';

const bannerImageUrl = typeof bannerImage === 'string' ? bannerImage : bannerImage.src;
const defaultMercadoPagoDonationUrl = 'https://mpago.la/2KpDFey';
const mercadoPagoDonationUrl = import.meta.env.PUBLIC_MERCADO_PAGO_DONATION_URL ?? defaultMercadoPagoDonationUrl;
const isMercadoPagoConfigured = /^https?:\/\//.test(mercadoPagoDonationUrl);

const donationAmounts = [
	{
		amount: '$50 MXN',
		title: 'Apoyo básico',
		description: 'Agradecimiento especial',
	},
	{
		amount: '$100 MXN',
		title: 'Apoyo de materiales',
		description: 'Apoyanos para seguir subiendo material y recursos de formación',
		paymentUrl: 'https://mpago.la/1tgpViD',
	},
	{
		amount: '$250 MXN',
		title: 'Apoyo de ensayo',
		description: 'Apoyanos para llegar a más coros',
		paymentUrl: 'https://mpago.la/1kKLK2q'
	},
	{
		amount: '$500 MXN',
		title: 'Apoyo comunitario',
		description: 'Impulsa el mantenimiento y crecimiento del sitio web.',
		paymentUrl: 'https://mpago.la/2bjsrCm'
	},
];

const donationUses = [
	'Preparación de partituras, acordes y materiales disponibles gratuitamente para todo el público.',
	'Mantenimiento de recursos del sitio web',
	'Apoyo a las Parroquias donde sirve Coro Beatus Dei',
];

const configuredDonationAmounts = donationAmounts.map(option => {
	const paymentUrl = option.paymentUrl ?? mercadoPagoDonationUrl;

	return {
		...option,
		paymentUrl,
		isPaymentConfigured: /^https?:\/\//.test(paymentUrl),
	};
});
---

<Layout
	title="Donativos para el ministerio de música"
	description="Apoya al Coro Beatus Dei para preparar partituras, acordes, impresiones y recursos litúrgicos para ensayos y celebraciones."
	image={bannerImageUrl}
>
	<div class="donations-page">
		<section
			class="donations-hero"
			style={`--donations-hero-bg: url(${bannerImageUrl});`}
		>
			<div class="donations-hero-inner">
				<p class="donations-label">Donativos</p>
				<h1>Apoya el servicio musical del Coro Beatus Dei</h1>
				<p>
					Tu donativo nos ayuda a preparar mejor los cantos, materiales y recursos
					que acompañan la liturgia en comunidad.
				</p>

				<div class="donations-actions">
					<a
						class={isMercadoPagoConfigured ? 'donation-main-button' : 'donation-main-button is-disabled'}
						href={isMercadoPagoConfigured ? mercadoPagoDonationUrl : '#configurar-mercado-pago'}
						target={isMercadoPagoConfigured ? '_blank' : undefined}
						rel={isMercadoPagoConfigured ? 'noreferrer' : undefined}
					>
						Donar con Mercado Pago
					</a>
					<span>Pago seguro en Mercado Pago</span>
				</div>
			</div>
		</section>

		<section class="donations-section">
			<div class="donations-section-head">
				<p class="donations-label">Elige una intención</p>
				<h2>Montos sugeridos</h2>
			</div>

			<div class="donation-grid">
				{configuredDonationAmounts.map(option => (
					<article class="donation-card">
						<span>{option.amount}</span>
						<h3>{option.title}</h3>
						<p>{option.description}</p>
						<a
							href={option.isPaymentConfigured ? option.paymentUrl : '#configurar-mercado-pago'}
							target={option.isPaymentConfigured ? '_blank' : undefined}
							rel={option.isPaymentConfigured ? 'noreferrer' : undefined}
						>
							Donar
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="donation-info">
			<div>
				<p class="donations-label">Tu apoyo se convierte en servicio</p>
				<h2>Qué ayudas a sostener</h2>
			</div>

			<ul>
				{donationUses.map(item => (
					<li>{item}</li>
				))}
			</ul>
		</section>

		{
			!isMercadoPagoConfigured && (
				<section id="configurar-mercado-pago" class="donation-config">
					<p class="donations-label">Configuración pendiente</p>
					<h2>Conecta el link real de Mercado Pago</h2>
					<p>
						Para activar la pasarela, crea un Link de Pago o una preferencia de
						Checkout Pro en Mercado Pago y agrega la URL en la variable
						<code>PUBLIC_MERCADO_PAGO_DONATION_URL</code>.
					</p>
					<pre><code>PUBLIC_MERCADO_PAGO_DONATION_URL="https://mpago.la/2KpDFey"</code></pre>
				</section>
			)
		}
	</div>
</Layout>
