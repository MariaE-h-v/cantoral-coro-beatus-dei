---
import Layout from '../../layouts/Layout.astro';
import '../../styles/resources.css';
import { videoResources } from '../../data/resources';
---

<Layout>
	<div class="resource-page">
		<section class="resource-hero compact">
			<div class="resource-hero-content">
				<a class="resource-back-link" href="/recursos">← Recursos</a>
				<p class="resource-label">Audios y videos</p>
				<h1>Referencias de escucha y preparación</h1>
				<p>
					Videos embebidos de YouTube para estudiar estilos, fraseo, balance
					vocal y acompañamientos antes de llevarlos al ensayo.
				</p>
			</div>
		</section>

		<section class="resource-section">
			<div class="video-grid">
				{videoResources.map(video => (
					<article class="video-card">
						<div class="video-frame">
							<iframe
								src={video.embedUrl}
								title={video.title}
								loading="lazy"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
								allowfullscreen
							></iframe>
						</div>
						<div class="video-copy">
							<h2>{video.title}</h2>
							<p>{video.description}</p>
							<a href={video.sourceUrl} target="_blank" rel="noreferrer">
								Ver en YouTube →
							</a>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>
</Layout>
