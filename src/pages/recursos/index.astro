---
import Layout from '../../layouts/Layout.astro';
import '../../styles/resources.css';
import { resourceCategories } from '../../data/resources';
---

<Layout
	title="Recursos para música litúrgica"
	description="Biblioteca de partituras, acordes, videos, guías para cantores y planeaciones para preparar la música de cada celebración."
	image="/assets/portada-impresion-cantos.webp"
>
	<div class="resource-page">
		<section class="resource-hero">
			<div class="resource-hero-content">
				<p class="resource-label">Biblioteca del ministerio</p>
				<h1>Recursos para preparar la música de cada celebración</h1>
				<p>
					Encuentra partituras, acordes, videos, guías y planeaciones para que
					el coro pueda ensayar con claridad y servir mejor en la liturgia.
				</p>
			</div>
		</section>

		<section class="resource-section">
			<div class="resource-section-head">
				<div>
					<p class="resource-label">Categorías</p>
					<h2>Elige el tipo de material</h2>
				</div>
			</div>

			<div class="resource-directory">
				{resourceCategories.map(resource => (
					<a class="resource-directory-card" href={resource.href}>
						<span class="resource-directory-icon">{resource.icon}</span>
						<span class="resource-card-meta">{resource.meta}</span>
						<strong>{resource.title}</strong>
						<p>{resource.description}</p>
						<span class="resource-link-text">Abrir recurso →</span>
					</a>
				))}
			</div>
		</section>

		<section class="resource-recommendations-section" aria-labelledby="recommendations-title">
			<div class="resource-section-head">
				<div>
					<p class="resource-label">Recomendaciones externas</p>
					<h2 id="recommendations-title">Sitios útiles para profundizar</h2>
				</div>
			</div>

			<div class="resource-recommendation-list">
				<div class="resource-recommendation" aria-label="Verbum Gloriae">
					<div class="resource-recommendation-logo">
						<img
							src="/assets/verbum-gloriae-banner.png"
							alt="Verbum Gloriae, canto gregoriano España"
							loading="lazy"
						/>
					</div>
					<div>
						<p class="resource-label">Recomendado</p>
						<h2>Verbum Gloriae</h2>
						<p>
							Una página con cantos gregorianos y recursos para profundizar en el
							canto litúrgico.
						</p>
					</div>
					<a
						class="resource-recommendation-link"
						href="https://www.verbumgloriae.es/"
						target="_blank"
						rel="noreferrer"
					>
						Visitar sitio
					</a>
				</div>

				<div class="resource-recommendation" aria-label="Liturgia Papal">
					<div class="resource-recommendation-logo">
						<img
							src="/assets/liturgia-papal-banner.png"
							alt="Liturgia Papal"
							loading="lazy"
						/>
					</div>
					<div>
						<p class="resource-label">Misal Romano</p>
						<h2>Liturgia Papal</h2>
						<p>
							Recurso para consultar el Misal Romano y otros libros litúrgicos útiles
							para preparar celebraciones con fidelidad al rito.
						</p>
					</div>
					<a
						class="resource-recommendation-link"
						href="https://liturgiapapal.org/index.php/recursos-lit%C3%BArgicos/libros-lit%C3%BArgicos/604-misal-romano.html"
						target="_blank"
						rel="noreferrer"
					>
						Abrir Misal Romano
					</a>
				</div>

				<div class="resource-recommendation" aria-label="Canto Litúrgico">
					<div class="resource-recommendation-logo">
						<img
							src="/assets/canto-liturgico-banner.png"
							alt="Canto Litúrgico, formación en música sacra"
							loading="lazy"
						/>
					</div>
					<div>
						<p class="resource-label">Formación musical</p>
						<h2>Canto Litúrgico</h2>
						<p>
							Sitio dedicado a la formación en música sacra y recursos para
							fortalecer el servicio musical dentro de la liturgia.
						</p>
					</div>
					<a
						class="resource-recommendation-link"
						href="https://www.cantoliturgico.com/"
						target="_blank"
						rel="noreferrer"
					>
						Visitar sitio
					</a>
				</div>
			</div>
		</section>

		<section class="resource-band">
			<div>
				<p class="resource-label">Flujo sugerido</p>
				<h2>De la planeación al ensayo</h2>
			</div>

			<div class="resource-steps">
				<article>
					<span>1</span>
					<strong>Define la celebración</strong>
					<p>Revisa el tiempo litúrgico, las lecturas y el momento de la misa.</p>
				</article>
				<article>
					<span>2</span>
					<strong>Elige los cantos</strong>
					<p>Usa el cantoral y separa el material que requiere piano o guitarra.</p>
				</article>
				<article>
					<span>3</span>
					<strong>Ensaya con referencias</strong>
					<p>Comparte videos, audios y PDFs antes del ensayo presencial.</p>
				</article>
			</div>
		</section>
	</div>
</Layout>
