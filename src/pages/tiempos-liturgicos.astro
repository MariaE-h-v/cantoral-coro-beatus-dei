---
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const rawSongs = import.meta.glob('../content/cantos/*.md', { eager: true });

const songs = Object.entries(rawSongs)
	.map(([file, module]) => {
		const data = (module as any).frontmatter ?? {};
		const slug = path.basename(file, '.md');

		return {
			title: data.title ?? slug,
			categoria: data.categoria ?? 'Canto',
			tipo: data.tipo ?? 'Canto',
			tiempo: data.tiempo ?? 'Sin tiempo',
			author: data.author ?? 'Autor desconocido',
			liturgico: Boolean(data.liturgico),
			description: data.description ?? 'Canto disponible para consulta dentro del cantoral.',
			slug,
			href: `/cantos/${slug}`,
		};
	})
	.sort((a, b) => a.title.localeCompare(b.title));

const normalize = (value: string) =>
	value
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.toLowerCase()
		.trim();

const liturgicalSeasons = [
	{
		title: 'Adviento',
		id: 'adviento',
		icon: 'A',
		background: '/assets/tiempos-card-adviento.png',
		planningHref: '/recursos/pdfs/planeaciones/adviento.pdf',
		subtitle: 'Tiempo de espera y preparación',
		description:
			'El Adviento abre el año litúrgico y prepara a la comunidad para la venida del Señor. Sus cantos suelen expresar vigilancia, esperanza y deseo de conversión.',
		aliases: ['Adviento'],
	},
	{
		title: 'Navidad',
		id: 'navidad',
		icon: 'N',
		background: '/assets/tiempos-card-navidad.png',
		planningHref: '/recursos/planeaciones',
		subtitle: 'Celebración del nacimiento de Cristo',
		description:
			'La Navidad contempla el misterio de la Encarnación. En este tiempo, el canto anuncia la alegría del Dios que se hace cercano y habita entre nosotros.',
		aliases: ['Navidad'],
	},
	{
		title: 'Cuaresma',
		id: 'cuaresma',
		icon: 'C',
		background: '/assets/tiempos-card-cuaresma.png',
		planningHref: '/recursos/pdfs/planeaciones/cuaresma.pdf',
		subtitle: 'Camino de conversión hacia la Pascua',
		description:
			'La Cuaresma invita al silencio interior, la penitencia y la vuelta al Evangelio. Sus cantos acompañan la oración, la misericordia y la preparación bautismal.',
		aliases: ['Cuaresma'],
	},
	{
		title: 'Triduo Pascual',
		id: 'triduo-pascual',
		icon: 'T',
		background: '/assets/tiempos-card-triduo-pascual.png',
		planningHref: '/recursos/pdfs/planeaciones/semana-santa.pdf',
		subtitle: 'Pasión, muerte y resurrección del Señor',
		description:
			'El Triduo Pascual es el centro del año litúrgico. Cada celebración pide cantos sobrios, profundos y muy unidos a los signos propios de estos días santos.',
		aliases: ['Triduo Pascual', 'Semana Santa', 'Jueves Santo', 'Viernes Santo', 'Vigilia Pascual'],
	},
	{
		title: 'Pascua',
		id: 'pascua',
		icon: 'P',
		background: '/assets/tiempos-card-pascua.png',
		planningHref: '/recursos/planeaciones',
		subtitle: 'Alegría por Cristo resucitado',
		description:
			'La Pascua celebra la victoria de Cristo sobre la muerte. Los cantos de este tiempo proclaman vida nueva, aleluya, luz y misión.',
		aliases: ['Pascua'],
	},
	{
		title: 'Tiempo Ordinario',
		id: 'tiempo-ordinario',
		icon: 'O',
		background: '/assets/tiempos-card-tiempo-ordinario.png',
		planningHref: '/recursos/pdfs/planeaciones/tiempo-ordinario.pdf',
		subtitle: 'La vida cotidiana iluminada por el Evangelio',
		description:
			'El Tiempo Ordinario recorre la vida pública de Jesús y la maduración de la fe. Permite cantos de alabanza, comunión, seguimiento y envío.',
		aliases: ['Tiempo ordinario', 'Ordinario'],
	},
	{
		title: 'Santos y solemnidades',
		id: 'santos',
		icon: 'S',
		background: '/assets/tiempos-card-santos.png',
		planningHref: '/recursos/pdfs/planeaciones/tiempo-ordinario.pdf',
		subtitle: 'Memorias, fiestas y celebraciones especiales',
		description:
			'Las fiestas de santos y solemnidades ayudan a cantar la obra de Dios en la Iglesia. Sus cantos suelen destacar la intercesión, la gratitud y la vocación cristiana.',
		aliases: ['Santos', 'Solemnidades', 'Fiestas'],
	},
];

const songsForSeason = (aliases: string[]) => {
	const normalizedAliases = aliases.map(alias => normalize(alias));

	return songs.filter(song =>
		normalizedAliases.includes(normalize(song.tiempo))
	);
};
---

<Layout
	title="Cantos por tiempos litúrgicos"
	description="Encuentra cantos para Adviento, Navidad, Cuaresma, Triduo Pascual, Pascua, Tiempo Ordinario y celebraciones de santos."
	image="/assets/tiempos-liturgicos-hero.png"
>
	<main class="seasons-page">
		<section class="seasons-hero">
			<div>
				<p class="seasons-label">Calendario litúrgico</p>
				<h1>Tiempos litúrgicos</h1>
				<p>
					Una guía para ubicar cada tiempo del año de la Iglesia y preparar cantos
					que acompañen mejor la celebración.
				</p>
			</div>
		</section>

		<nav class="season-index" aria-label="Tiempos litúrgicos">
			{liturgicalSeasons.map(season => {
				const count = songsForSeason(season.aliases).length;

				return (
					<a
						href={`#${season.id}`}
						class="season-index-link"
						style={`--season-card-bg: url('${season.background}');`}
					>
						<span>{season.icon}</span>
						<strong>{season.title}</strong>
						<small>{count} {count === 1 ? 'canto' : 'cantos'}</small>
					</a>
				);
			})}
		</nav>

		<div class="season-sections">
			{liturgicalSeasons.map(season => {
				const seasonSongs = songsForSeason(season.aliases);
				const filterTarget = `/cantos?tiempo=${encodeURIComponent(season.aliases[0])}`;
				const planningIsPdf = season.planningHref.endsWith('.pdf');

				return (
					<section
						id={season.id}
						class="season-detail"
						style={`--season-card-bg: url('${season.background}');`}
					>
						<div class="season-copy">
							<span class="season-mark" aria-hidden="true">{season.icon}</span>
							<p class="seasons-label">{season.subtitle}</p>
							<h2>{season.title}</h2>
							<p>{season.description}</p>
							<div class="season-actions">
								<a class="season-filter-link" href={filterTarget}>
									Ver en el cantoral
								</a>
								<a
									class="season-planning-link"
									href={season.planningHref}
									target={planningIsPdf ? '_blank' : undefined}
									rel={planningIsPdf ? 'noreferrer' : undefined}
								>
									Ver planeación
								</a>
							</div>
						</div>

						<div class="season-song-list">
							<div class="season-list-head">
								<h3>Cantos para {season.title}</h3>
								<span>{seasonSongs.length}</span>
							</div>

							{seasonSongs.length ? (
								<ul data-season-song-scroll>
									{seasonSongs.map(song => (
										<li>
											<a href={song.href}>
												<span>
													<strong>{song.title}</strong>
													<small>{song.description}</small>
												</span>

												<span class="song-meta">
													<span>{song.categoria}</span>
													<span>{song.author}</span>
												</span>
											</a>
										</li>
									))}
								</ul>
							) : (
								<p class="season-empty">
									Aún no hay cantos registrados para este tiempo.
								</p>
							)}
						</div>
					</section>
				);
			})}
		</div>
	</main>
</Layout>

<script>
	const limitSeasonSongLists = () => {
		document.querySelectorAll<HTMLElement>('[data-season-song-scroll]').forEach(list => {
			const items = Array.from(list.children).filter(item => item instanceof HTMLElement);

			if (items.length <= 3) {
				list.classList.remove('is-scrollable');
				list.removeAttribute('style');
				return;
			}

			const styles = window.getComputedStyle(list);
			const gap = Number.parseFloat(styles.rowGap || styles.gap || '0') || 0;
			const visibleHeight = items
				.slice(0, 3)
				.reduce((total, item) => total + item.getBoundingClientRect().height, 0);

			list.style.maxHeight = `${Math.ceil(visibleHeight + gap * 2)}px`;
			list.classList.add('is-scrollable');
		});
	};

	const refreshSeasonSongLists = () => {
		window.requestAnimationFrame(limitSeasonSongLists);
	};

	refreshSeasonSongLists();
	window.addEventListener('load', refreshSeasonSongLists);
	window.addEventListener('resize', refreshSeasonSongLists);
	document.fonts?.ready.then(refreshSeasonSongLists);
</script>

<style>
	.seasons-page {
		width: min(1160px, calc(100% - 56px));
		margin: 0 auto;
		padding: 42px 0 28px;
		font-family: Inter, system-ui, sans-serif;
	}

	.seasons-hero {
		position: relative;
		display: flex;
		min-height: 340px;
		align-items: center;
		overflow: hidden;
		margin-bottom: 24px;
		padding: 36px;
		border-radius: 28px;
		background:
			linear-gradient(90deg, rgba(255, 248, 239, 0.98) 0%, rgba(255, 248, 239, 0.94) 44%, rgba(255, 248, 239, 0.62) 72%, rgba(255, 248, 239, 0.24) 100%),
			url('/assets/tiempos-liturgicos-hero.png') center / cover no-repeat,
			white;
		border: 1px solid #eee7dc;
		box-shadow: 0 24px 70px rgba(15, 23, 42, 0.07);
	}

	.seasons-hero > div {
		position: relative;
		z-index: 1;
	}

	.seasons-label {
		margin: 0 0 8px;
		color: #b27722;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.seasons-hero h1,
	.season-copy h2 {
		margin: 0;
		color: #171717;
		font-family: Georgia, 'Times New Roman', serif;
		font-weight: 500;
		line-height: 1;
	}

	.seasons-hero h1 {
		font-size: clamp(2.6rem, 5vw, 4.6rem);
	}

	.seasons-hero p:not(.seasons-label) {
		max-width: 720px;
		margin: 16px 0 0;
		color: #64748b;
		font-size: 1.04rem;
		line-height: 1.75;
	}

	.season-index {
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 10px;
		margin-bottom: 26px;
	}

	.season-index-link {
		position: relative;
		display: grid;
		gap: 7px;
		align-content: start;
		overflow: hidden;
		isolation: isolate;
		min-height: 126px;
		padding: 14px;
		border-radius: 18px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 248, 239, 0.82) 58%, rgba(255, 255, 255, 0.68) 100%),
			var(--season-card-bg) center / cover no-repeat,
			white;
		border: 1px solid #eee7dc;
		color: #111827;
		text-decoration: none;
		box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.season-index-link:hover {
		transform: translateY(-2px);
		border-color: rgba(178, 119, 34, 0.32);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.09);
	}

	.season-index-link span,
	.season-mark {
		display: inline-flex;
		width: 38px;
		height: 38px;
		align-items: center;
		justify-content: center;
		border-radius: 13px;
		background: rgba(255, 247, 237, 0.92);
		border: 1px solid #f1e4d1;
		color: #9a5f18;
		font-weight: 900;
		backdrop-filter: blur(4px);
	}

	.season-index-link strong {
		font-size: 0.95rem;
		line-height: 1.25;
	}

	.season-index-link small {
		color: #64748b;
		font-weight: 750;
	}

	.season-sections {
		display: grid;
		gap: 22px;
	}

	.season-detail {
		display: grid;
		grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.35fr);
		gap: 24px;
		align-items: start;
		overflow: hidden;
		padding: 24px;
		border-radius: 28px;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 250, 244, 0.91) 47%, rgba(255, 255, 255, 0.76) 100%),
			var(--season-card-bg) center / cover no-repeat,
			white;
		border: 1px solid #eee7dc;
		box-shadow: 0 18px 54px rgba(15, 23, 42, 0.06);
		scroll-margin-top: 98px;
	}

	.season-copy {
		display: grid;
		gap: 12px;
	}

	.season-copy h2 {
		font-size: clamp(2rem, 3vw, 3rem);
	}

	.season-copy p:not(.seasons-label) {
		margin: 0;
		color: #64748b;
		line-height: 1.75;
	}

	.season-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 4px;
	}

	.season-filter-link,
	.season-planning-link {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		justify-content: center;
		padding: 0.72rem 1rem;
		border-radius: 999px;
		font-weight: 900;
		text-decoration: none;
		line-height: 1.1;
	}

	.season-filter-link {
		background: #24456f;
		color: white;
		box-shadow: 0 12px 26px rgba(36, 69, 111, 0.18);
	}

	.season-planning-link {
		background: rgba(255, 247, 237, 0.92);
		border: 1px solid #e8d3af;
		color: #8a520f;
		box-shadow: 0 12px 24px rgba(138, 82, 15, 0.12);
	}

	.season-song-list {
		padding: 18px;
		border-radius: 22px;
		background: rgba(255, 250, 244, 0.92);
		border: 1px solid #f1e4d1;
		backdrop-filter: blur(6px);
	}

	.season-list-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		margin-bottom: 12px;
	}

	.season-list-head h3 {
		margin: 0;
		color: #111827;
		font-size: 1rem;
	}

	.season-list-head span {
		display: inline-flex;
		min-width: 34px;
		height: 34px;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: white;
		border: 1px solid #f1e4d1;
		color: #8a520f;
		font-weight: 900;
	}

	.season-song-list ul {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.season-song-list ul.is-scrollable {
		overflow-y: auto;
		overscroll-behavior: contain;
		padding-right: 8px;
		scrollbar-color: #d8c8af rgba(255, 255, 255, 0.64);
		scrollbar-gutter: stable;
		scrollbar-width: thin;
	}

	.season-song-list ul.is-scrollable::-webkit-scrollbar {
		width: 8px;
	}

	.season-song-list ul.is-scrollable::-webkit-scrollbar-track {
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.64);
	}

	.season-song-list ul.is-scrollable::-webkit-scrollbar-thumb {
		border-radius: 999px;
		background: #d8c8af;
	}

	.season-song-list li a {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 14px;
		align-items: center;
		padding: 14px;
		border-radius: 16px;
		background: white;
		border: 1px solid #f1e8dd;
		color: inherit;
		text-decoration: none;
	}

	.season-song-list strong,
	.season-song-list small {
		display: block;
	}

	.season-song-list strong {
		color: #111827;
		font-size: 1rem;
	}

	.season-song-list small {
		margin-top: 4px;
		color: #64748b;
		line-height: 1.5;
	}

	.song-meta {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 6px;
		color: #475569;
		font-size: 0.8rem;
		font-weight: 750;
	}

	.song-meta span {
		padding: 0.32em 0.68em;
		border-radius: 999px;
		background: #f8fafc;
		border: 1px solid #e5e7eb;
	}

	.season-empty {
		margin: 0;
		padding: 18px;
		border-radius: 16px;
		background: white;
		border: 1px dashed #d8c8af;
		color: #64748b;
		line-height: 1.6;
	}

	@media (max-width: 1100px) {
		.season-index {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.season-detail {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.seasons-page {
			width: min(100% - 32px, 1160px);
			padding-top: 28px;
		}

		.seasons-hero,
		.season-detail {
			padding: 22px;
			border-radius: 22px;
		}

		.seasons-hero {
			min-height: 330px;
			background:
				linear-gradient(180deg, rgba(255, 248, 239, 0.98) 0%, rgba(255, 248, 239, 0.94) 64%, rgba(255, 248, 239, 0.72) 100%),
				url('/assets/tiempos-liturgicos-hero.png') center right / cover no-repeat,
				white;
		}

		.season-index {
			grid-template-columns: 1fr;
		}

		.season-index-link {
			min-height: auto;
		}

		.season-detail {
			background:
				linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(255, 250, 244, 0.9) 68%, rgba(255, 255, 255, 0.8) 100%),
				var(--season-card-bg) center / cover no-repeat,
				white;
		}

		.season-song-list li a {
			grid-template-columns: 1fr;
		}

		.song-meta {
			justify-content: flex-start;
		}
	}
</style>
